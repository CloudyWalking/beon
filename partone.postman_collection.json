    {
      "name": "getbook",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "const storedFirstname = pm.collectionVariables.get(\"firstname\");\r",
              "const storedLastname = pm.collectionVariables.get(\"lastname\");\r",
              "const storedTotalprice = pm.collectionVariables.get(\"totalprice\");\r",
              "\r",
              "pm.test(\"firstname matches stored value\", function () {\r",
              "    pm.expect(jsonData.firstname).to.eql(storedFirstname);\r",
              "});\r",
              "\r",
              "pm.test(\"lastname matches stored value\", function () {\r",
              "    pm.expect(jsonData.lastname).to.eql(storedLastname);\r",
              "});\r",
              "\r",
              "pm.test(\"totalprice matches stored value\", function () {\r",
              "    pm.expect(jsonData.totalprice).to.eql(Number(storedTotalprice));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
